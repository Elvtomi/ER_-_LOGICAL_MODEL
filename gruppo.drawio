        <mxCell id="jufeQy_zDKF2IxAp9iGt-29" parent="1" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;" value="*Ho scelto una gerarchia &lt;b&gt;parziale &lt;/b&gt;perché potrebbero esserci altri performer (i.e.ballerini) come membri di un gruppo e &lt;b&gt;non esclusiva &lt;/b&gt;perché uno strumentista potrebbe essere anche cantante (i.e. Edoardo Bennato)" vertex="1">
          <mxGeometry height="100" width="180" x="-150" y="230" as="geometry" />
        </mxCell>
        <mxCell id="jufeQy_zDKF2IxAp9iGt-30" parent="1" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;" value="1,N" vertex="1">
