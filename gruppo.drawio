        <mxCell id="jufeQy_zDKF2IxAp9iGt-50" parent="1" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;" value="SCHEMA LOGICO:&amp;nbsp;&lt;div&gt;GRUPPO(&lt;u style=&quot;font-weight: bold;&quot;&gt;Codice_gruppo, &lt;/u&gt;Nome, anno_fondazione)&lt;/div&gt;&lt;div&gt;COMPONENTE (&lt;b&gt;&lt;u&gt;Codice_componente&lt;/u&gt;&lt;/b&gt;, Nome, Nazionalità, anno di nascita)&lt;/div&gt;&lt;div&gt;STRUMENTISTA(&lt;b&gt;&lt;u&gt;Codice_componente&lt;/u&gt;&lt;/b&gt;, strumento preferito)&lt;/div&gt;&lt;div&gt;FK (&lt;b style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;&lt;u&gt;Codice_componente&lt;/u&gt;&lt;/b&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;)-&amp;gt; COMPONENTE (&lt;/span&gt;&lt;b style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;&lt;u&gt;Codice_componente)&lt;/u&gt;&lt;/b&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;CANTANTE(&lt;/span&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;&lt;b style=&quot;text-decoration-line: underline;&quot;&gt;Codice_componente,&lt;/b&gt;canzoni incise&lt;b style=&quot;text-decoration-line: underline;&quot;&gt;)&lt;/b&gt;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;FK (&lt;b style=&quot;color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255)); background-color: transparent;&quot;&gt;&lt;u&gt;Codice_componente&lt;/u&gt;&lt;/b&gt;&lt;span style=&quot;color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255)); background-color: transparent;&quot;&gt;)-&amp;gt; COMPONENTE (&lt;/span&gt;&lt;b style=&quot;color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255)); background-color: transparent;&quot;&gt;&lt;u&gt;Codice_componente)&lt;/u&gt;&lt;/b&gt;&lt;span style=&quot;background-color: t